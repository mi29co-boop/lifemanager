<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>LifeManager</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Arial,sans-serif;background:#1a1a2e;color:#fff;min-height:100vh}
.sidebar{width:250px;background:#16213e;height:100vh;position:fixed;padding:20px}
.logo{font-size:24px;font-weight:bold;margin-bottom:30px;color:#e94560}
.nav-btn{display:block;width:100%;padding:12px;margin-bottom:8px;background:#0f3460;border:none;color:#fff;border-radius:8px;cursor:pointer}
.nav-btn:hover,.nav-btn.active{background:#e94560}
.main{margin-left:250px;padding:30px}
.card{background:#16213e;border-radius:12px;padding:20px;margin-bottom:20px}
input,textarea,select{width:100%;padding:10px;margin:8px 0;background:#0f3460;border:1px solid #533483;color:#fff;border-radius:6px}
button{padding:10px 20px;background:#e94560;color:#fff;border:none;border-radius:6px;cursor:pointer}
button:hover{background:#ff6b6b}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.hidden{display:none}
</style>
</head>
<body>
<div class="sidebar">
<div class="logo">LifeManager</div>
<button class="nav-btn active" onclick="show('dash')">Dashboard</button>
<button class="nav-btn" onclick="show('cal')">Terminplaner</button>
<button class="nav-btn" onclick="show('note')">Notizen</button>
<button class="nav-btn" onclick="show('calc')">Rechner</button>
<button class="nav-btn" onclick="show('bud')">Haushalt</button>
</div>

<div class="main">
<div id="dash" class="page">
<h1>Dashboard</h1>
<div class="grid">
<div class="card"><h3>Heutige Termine</h3><div id="dEvents">Keine Termine</div></div>
<div class="card"><h3>Letzte Notizen</h3><div id="dNotes">Keine Notizen</div></div>
<div class="card"><h3>Kontostand</h3><h2 id="dBal">0,00 €</h2></div>
<div class="card"><h3>Schnellrechner</h3><input id="qc" placeholder="z.B. 15*4"><button onclick="qc()">=</button><div id="qr"></div></div>
</div>
</div>

<div id="cal" class="page hidden">
<h1>Terminplaner</h1>
<div class="grid">
<div class="card">
<div id="calHeader"></div>
<div id="calGrid" style="display:grid;grid-template-columns:repeat(7,1fr);gap:5px"></div>
</div>
<div class="card">
<h3>Neuer Termin</h3>
<input id="eTitle" placeholder="Titel">
<input type="date" id="eDate">
<input type="time" id="eTime">
<button onclick="addEvent()">Speichern</button>
<h3>Termine</h3><div id="eList"></div>
</div>
</div>
</div>

<div id="note" class="page hidden">
<h1>Notizen</h1>
<div class="card">
<input id="nTitle" placeholder="Titel">
<textarea id="nText" placeholder="Notiz..." rows="4"></textarea>
<button onclick="addNote()">Speichern</button>
</div>
<div id="nList"></div>
</div>

<div id="calc" class="page hidden">
<h1>Rechner</h1>
<div class="card" style="max-width:400px;margin:0 auto">
<div id="cDisp" style="text-align:right;font-size:32px;margin-bottom:10px">0</div>
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:5px">
<button onclick="ca()">C</button><button onclick="cd()">←</button><button onclick="co('%')">%</button><button onclick="co('/')">/</button>
<button onclick="cn('7')">7</button><button onclick="cn('8')">8</button><button onclick="cn('9')">9</button><button onclick="co('*')">*</button>
<button onclick="cn('4')">4</button><button onclick="cn('5')">5</button><button onclick="cn('6')">6</button><button onclick="co('-')">-</button>
<button onclick="cn('1')">1</button><button onclick="cn('2')">2</button><button onclick="cn('3')">3</button><button onclick="co('+')">+</button>
<button onclick="cn('0')" style="grid-column:span 2">0</button><button onclick="cn('.')">.</button><button onclick="ce()">=</button>
</div>
</div>
</div>

<div id="bud" class="page hidden">
<h1>Haushaltsplaner</h1>
<div class="grid">
<div class="card">
<h3>Neue Transaktion</h3>
<input id="tDesc" placeholder="Beschreibung">
<input type="number" id="tAmt" placeholder="Betrag">
<select id="tType"><option value="in">Einnahme</option><option value="out">Ausgabe</option></select>
<button onclick="addTrans()">Hinzufügen</button>
</div>
<div class="card">
<h3>Übersicht</h3>
<p>Einnahmen: <span id="tIn">0</span> €</p>
<p>Ausgaben: <span id="tOut">0</span> €</p>
<p>Kontostand: <span id="tBal">0</span> €</p>
<h3>Transaktionen</h3><div id="tList"></div>
</div>
</div>
</div>
</div>

<script>
let events=JSON.parse(localStorage.getItem('ev')||'[]');
let notes=JSON.parse(localStorage.getItem('no')||'[]');
let trans=JSON.parse(localStorage.getItem('tr')||'[]');
let ceq='',cdt=new Date();

function show(id){document.querySelectorAll('.page').forEach(p=>p.classList.add('hidden'));document.getElementById(id).classList.remove('hidden');if(id=='dash')updDash();if(id=='cal')renderCal();if(id=='note')renderNotes();if(id=='bud')renderTrans()}
function updDash(){let t=new Date().toISOString().split('T')[0];let te=events.filter(e=>e.d==t);document.getElementById('dEvents').innerHTML=te.length?te.map(e=>`<p>${e.t} ${e.time||''}</p>`).join(''):'Keine Termine';document.getElementById('dNotes').innerHTML=notes.slice(0,3).map(n=>`<p><b>${n.t}</b></p>`).join('')||'Keine Notizen';let b=trans.reduce((a,t)=>a+(t.type=='in'?t.a:-t.a),0);document.getElementById('dBal').textContent=b.toFixed(2)+' €'}
function renderCal(){let y=cdt.getFullYear(),m=cdt.getMonth();document.getElementById('calHeader').innerHTML=`<button onclick="cm(-1)">←</button> ${['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'][m]} ${y} <button onclick="cm(1)">→</button>`;let fd=new Date(y,m,1).getDay()||7;let dm=new Date(y,m+1,0).getDate();let h='';for(let i=1;i<fd;i++)h+='<div></div>';for(let d=1;d<=dm;d++){let ds=`${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;h+=`<div style="padding:10px;background:${events.some(e=>e.d==ds)?'#e94560':'#0f3460'};border-radius:6px;cursor:pointer" onclick="sd('${ds}')">${d}</div>`}document.getElementById('calGrid').innerHTML=h}
function cm(d){cdt.setMonth(cdt.getMonth()+d);renderCal()}function sd(d){document.getElementById('eDate').value=d}
function addEvent(){let t=document.getElementById('eTitle').value,d=document.getElementById('eDate').value,time=document.getElementById('eTime').value;if(!t||!d)return;events.push({id:Date.now(),t,d,time});localStorage.setItem('ev',JSON.stringify(events));renderEvents();renderCal();updDash()}
function renderEvents(){document.getElementById('eList').innerHTML=events.map(e=>`<p>${e.t} - ${e.d} ${e.time||''} <button onclick="delEv(${e.id})">X</button></p>`).join('')}
function delEv(id){events=events.filter(e=>e.id!=id);localStorage.setItem('ev',JSON.stringify(events));renderEvents();renderCal();updDash()}
function addNote(){let t=document.getElementById('nTitle').value,txt=document.getElementById('nText').value;if(!t&&!txt)return;notes.unshift({id:Date.now(),t:t||'Ohne Titel',txt});localStorage.setItem('no',JSON.stringify(notes));document.getElementById('nTitle').value='';document.getElementById('nText').value='';renderNotes();updDash()}
function renderNotes(){document.getElementById('nList').innerHTML=notes.map(n=>`<div class="card"><h4>${n.t}</h4><p>${n.txt}</p><button onclick="delNote(${n.id})">Löschen</button></div>`).join('')}
function delNote(id){notes=notes.filter(n=>n.id!=id);localStorage.setItem('no',JSON.stringify(notes));renderNotes();updDash()}
function cn(n){ceq+=n;document.getElementById('cDisp').textContent=ceq||'0'}function co(o){if(ceq&&!['+','-','*','/'].includes(ceq.slice(-1)))ceq+=o;document.getElementById('cDisp').textContent=ceq}function ca(){ceq='';document.getElementById('cDisp').textContent='0'}function cd(){ceq=ceq.slice(0,-1);document.getElementById('cDisp').textContent=ceq||'0'}
function ce(){try{let r=eval(ceq);document.getElementById('cDisp').textContent=r;ceq=String(r)}catch{document.getElementById('cDisp').textContent='Fehler';setTimeout(()=>{ceq='';document.getElementById('cDisp').textContent='0'},1000)}}
function qc(){try{document.getElementById('qr').textContent=eval(document.getElementById('qc').value)+' €'}catch{document.getElementById('qr').textContent='Fehler'}}
function addTrans(){let d=document.getElementById('tDesc').value,a=parseFloat(document.getElementById('tAmt').value),ty=document.getElementById('tType').value;if(!d||isNaN(a))return;trans.unshift({id:Date.now(),d,a,type:ty});localStorage.setItem('tr',JSON.stringify(trans));document.getElementById('tDesc').value='';document.getElementById('tAmt').value='';renderTrans();updDash()}
function renderTrans(){let i=trans.filter(t=>t.type=='in').reduce((a,t)=>a+t.a,0),o=trans.filter(t=>t.type=='out').reduce((a,t)=>a+t.a,0);document.getElementById('tIn').textContent=i.toFixed(2);document.getElementById('tOut').textContent=o.toFixed(2);document.getElementById('tBal').textContent=(i-o).toFixed(2);document.getElementById('tList').innerHTML=trans.map(t=>`<p>${t.d}: ${t.type=='in'?'+':'-'}${t.a.toFixed(2)} € <button onclick="delTr(${t.id})">X</button></p>`).join('')}
function delTr(id){trans=trans.filter(t=>t.id!=id);localStorage.setItem('tr',JSON.stringify(trans));renderTrans();updDash()}
updDash();renderCal();renderEvents();renderNotes();renderTrans()
</script>
</body>
</html>